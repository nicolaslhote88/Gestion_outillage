        "options": {
          "responseCode": 401
        }
      },
      "id": "respond-error",
      "name": "Respond Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 420]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: 'Drive folder deletion failed: ' + $json.message, code: 500 }) }}",
        "options": {
          "responseCode": 500
        }
      },
      "id": "respond-drive-error",
      "name": "Respond Drive Error",
      "type": "n8n-nodes-base.respondToWebhook",
